# =============================================================================
# Ansible Lint Configuration
# =============================================================================
# Rules and exceptions for ansible-lint. Run with:
#   ansible-lint site.yml bootstrap.yml playbooks roles
# =============================================================================

---
profile: production

# Exclude paths from linting
exclude_paths:
  - .ansible_cache/
  - collections/
  - inventory/k3s-token.txt
  - inventory/kubeconfig
  - inventory/hosts.ini  # Generated by Terraform
  - "**/*.md"

# Rules to skip (with justification)
skip_list:
  # We intentionally disable host key checking for homelab VMs
  - risky-file-permissions
  # Some tasks need to run as shell commands
  - command-instead-of-module
  # We use set_fact for complex variable resolution
  - no-handler
  # Keep existing role variable names unchanged
  - var-naming[no-role-prefix]

# Warning list (flag but don't fail)
warn_list:
  - experimental
  - ignore-errors

# # Rules to enforce with custom settings
# rules:
#   # Line length (modern terminals can handle more than 80)
#   line-length:
#     max: 160

# Enable specific rules that are off by default
enable_list:
  - no-same-owner
  - no-relative-paths

# Parseable output format for CI
quiet: false
verbosity: 1
