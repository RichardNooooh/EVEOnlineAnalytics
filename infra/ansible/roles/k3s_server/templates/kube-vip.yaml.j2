# /var/lib/rancher/k3s/server/manifests/kube-vip.yaml
# Managed by Ansible — do not edit manually on nodes.
#
# This manifest is auto-deployed by k3s on startup. It provides a
# Virtual IP (VIP) for the Kubernetes API server, enabling stable
# kubectl access and node registration that survives individual
# node failures.
#
# Deployed to node 1 ONLY, before k3s starts. Once k3s applies it,
# the DaemonSet runs on all control-plane nodes automatically.
#
# Docs:
#   - https://kube-vip.io/docs/usage/k3s/
#   - https://kube-vip.io/docs/installation/daemonset/
#   - https://docs.k3s.io/datastore/cluster-loadbalancer
#
# IMPORTANT: kube-vip is configured with --controlplane ONLY.
# Service load balancing (--services) is NOT enabled, because
# k3s's built-in ServiceLB handles LoadBalancer services. Running
# both would cause conflicts (duplicate external IP assignment).

# ==============================================================
# RBAC: ServiceAccount, ClusterRole, ClusterRoleBinding
# ==============================================================
# kube-vip needs permissions to:
#   - Watch/list nodes (to know which control-plane nodes exist)
#   - Manage leases in kube-system (for leader election)
#   - Watch services/endpoints (required even in CP-only mode
#     for the kube-vip manager to start cleanly)
#
# Ref: https://kube-vip.io/docs/installation/daemonset/
#   "RBAC resources are needed to ensure a ServiceAccount exists
#    with those permissions and bound appropriately."
# ==============================================================

apiVersion: v1
kind: ServiceAccount
metadata:
  name: kube-vip
  namespace: kube-system
---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRole
metadata:
  name: kube-vip-role
rules:
rules:
  # Read-only access to core resources
  - apiGroups: [""]
    resources: ["services", "endpoints", "nodes"]
    verbs: ["list", "get", "watch"]
  # Write access to service status only (for LB IP assignment)
  - apiGroups: [""]
    resources: ["services/status"]
    verbs: ["update"]
  # Leader election via Lease objects
  - apiGroups: ["coordination.k8s.io"]
    resources: ["leases"]
    verbs: ["list", "get", "watch", "create", "update"]
---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRoleBinding
metadata:
  name: kube-vip-binding
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: ClusterRole
  name: kube-vip-role
subjects:
  - kind: ServiceAccount
    name: kube-vip
    namespace: kube-system
---
# ==============================================================
# DaemonSet: kube-vip in ARP mode, control-plane only
# ==============================================================
# Key flags (mapped to env vars):
#
#   cp_enable=true        → Manage the VIP for the control plane
#   svc_enable=false      → Do NOT manage LoadBalancer services
#   vip_arp=true          → Use ARP (layer 2) to announce the VIP
#   vip_leaderelection    → One node holds the VIP at a time;
#                           leadership transfers on failure
#
# The DaemonSet uses nodeAffinity to run ONLY on nodes labeled
# with node-role.kubernetes.io/master OR
# node-role.kubernetes.io/control-plane. In current k3s, server
# nodes get both labels, so either matcher works.
#
# Ref: https://kube-vip.io/docs/installation/daemonset/
#   "--inCluster and --taint are needed to configure the
#    DaemonSet to use a ServiceAccount and affine the kube-vip
#    Pods to control plane nodes."
# ==============================================================

apiVersion: apps/v1
kind: DaemonSet
metadata:
  name: kube-vip-ds
  namespace: kube-system
  labels:
    app.kubernetes.io/name: kube-vip-ds
spec:
  selector:
    matchLabels:
      app.kubernetes.io/name: kube-vip-ds
  template:
    metadata:
      labels:
        app.kubernetes.io/name: kube-vip-ds
    spec:
      serviceAccountName: kube-vip
      hostNetwork: true
      tolerations:
        # Tolerate control-plane taints so the DaemonSet can
        # schedule even if taints are added later.
        - key: node-role.kubernetes.io/master
          effect: NoSchedule
        - key: node-role.kubernetes.io/control-plane
          effect: NoSchedule
      affinity:
        nodeAffinity:
          requiredDuringSchedulingIgnoredDuringExecution:
            nodeSelectorTerms:
              # k3s labels server nodes with BOTH of these.
              # Using OR (separate terms) ensures compatibility
              # across k3s versions.
              - matchExpressions:
                  - key: node-role.kubernetes.io/master
                    operator: Exists
              - matchExpressions:
                  - key: node-role.kubernetes.io/control-plane
                    operator: Exists
      containers:
        - name: kube-vip
          image: "ghcr.io/kube-vip/kube-vip:{{ kube_vip_version }}"
          imagePullPolicy: IfNotPresent
          args:
            - manager
          env:
            # ---- VIP address and interface ----
            - name: address
              value: "{{ k3s_vip_address }}"
            - name: vip_interface
              value: "{{ kube_vip_interface }}"
            - name: vip_subnet
              value: "32"

            # ---- Control plane VIP ----
            - name: cp_enable
              value: "true"
            - name: cp_namespace
              value: "kube-system"
            - name: port
              value: "6443"

            # ---- Service load balancing: DISABLED ----
            # ServiceLB (built into k3s) handles this.
            - name: svc_enable
              value: "false"

            # ---- ARP mode ----
            - name: vip_arp
              value: "true"

            # ---- Leader election ----
            # One node holds the VIP at a time. On failure,
            # leadership (and the VIP) transfers to another
            # control-plane node within leaseduration seconds.
            - name: vip_leaderelection
              value: "true"
            - name: vip_leaseduration
              value: "5"
            - name: vip_renewdeadline
              value: "3"
            - name: vip_retryperiod
              value: "1"

            # ---- Misc ----
            - name: vip_ddns
              value: "false"
            # Prometheus metrics endpoint (optional, useful for
            # VictoriaMetrics scraping later)
            - name: prometheus_server
              value: ":2112"
          securityContext:
            capabilities:
              add:
                # NET_ADMIN: required to add/remove the VIP
                # address on the network interface.
                - NET_ADMIN
                # NET_RAW: required to send gratuitous ARP
                # packets announcing the VIP.
                - NET_RAW

