# Local-only Airflow + dlt demo settings. Copy to infra/local/.env and edit there.

AIRFLOW_VERSION=3.2.1
PYTHON_VERSION=3.14
AIRFLOW_UID=50000

POSTGRES_DB=airflow
POSTGRES_USER=airflow
