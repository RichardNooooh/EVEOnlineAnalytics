# =============================================================================
# terraform.tfvars.example
# =============================================================================
# Copy this to terraform.tfvars and fill in your values.
# terraform.tfvars should be .gitignored.
# =============================================================================

# -----------------------------------------------------------------------------
# Node Configuration
# -----------------------------------------------------------------------------

k3s_nodes = {
  "k3s-1" = {
    node_name = "pve1"
    vm_id     = 201
    ip_addr   = "10.218.20.201/24"
  }
  "k3s-2" = {
    node_name = "pve2"
    vm_id     = 202
    ip_addr   = "10.218.20.202/24"
  }
  "k3s-3" = {
    node_name = "pve3"
    vm_id     = 203
    ip_addr   = "10.218.20.203/24"
  }
}

postgresql_vm_enabled   = true
postgresql_vm_name      = "postgresql-1"
postgresql_vm_node_name = "pve3"
postgresql_vm_id        = 204
postgresql_vm_ip_addr   = "10.218.20.204/24"

gateway = "10.218.20.1"

# -----------------------------------------------------------------------------
# Proxmox Connection
# -----------------------------------------------------------------------------

proxmox_api_url      = "https://pve1.cluster.internal:8006/"
proxmox_api_token    = "terraform@pve!opentofu=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
proxmox_tls_insecure = false
proxmox_ssh_user     = "root"

# SSH Keys — Proxmox key is used for cloud-init public key injection
# Ansible key defaults to the same as Proxmox if not specified
ssh_key_path_proxmox = "/home/USER/.ssh/id_ed25519"
# ssh_key_path_ansible = "/home/USER/.ssh/id_ed25519"  # Optional: defaults to ssh_key_path_proxmox

ansible_user = "ansible"
timezone     = "America/New_York" # adjust to your timezone

# VM sizing — tuned for 16 GB Proxmox nodes (~13 GB usable)
vm_cpu_cores    = 4
vm_memory_mb    = 8000 # 8 GB per VM
vm_disk_size_gb = 40

# PostgreSQL VM sizing
postgresql_vm_cpu_cores   = 2
postgresql_vm_memory_mb   = 4096
postgresql_vm_disk_size_gb = 40

# Database identities for generated app credentials and Kubernetes env files
postgresql_airflow_database_name = "airflow"
postgresql_airflow_username      = "airflow"
postgresql_mlflow_database_name  = "mlflow"
postgresql_mlflow_username       = "mlflow"

# Networking — adjust to your VLAN setup
vm_network_bridge = "vmbr0"
vm_vlan_id        = 20
dns_servers       = ["10.218.20.90"]
dns_search_domain = "internal"
