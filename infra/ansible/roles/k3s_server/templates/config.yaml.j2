# /etc/rancher/k3s/config.yaml
# Managed by Ansible — do not edit manually on nodes.
#
# Docs: https://docs.k3s.io/installation/configuration
#
# IMPORTANT: Network-related flags and component-disable flags
# MUST be identical across all server nodes, or the cluster
# will behave unpredictably.
#   Ref: https://docs.k3s.io/datastore/ha-embedded

# --------------------------------------------------------------
# Cluster membership
# --------------------------------------------------------------
# Node 1 initializes the cluster; nodes 2-3 join via the VIP.
{% if k3s_is_first_node %}
cluster-init: true
{% else %}
server: "https://{{k3s_vip_address}}:6443"
{% endif %}

# Shared token used by all servers to join the cluster.
# This is the "short" format — the secure format (with CA hash)
# cannot be known until after the first server generates its
# self-signed CA certificates.
token: {{ k3s_cluster_token }}

# --------------------------------------------------------------
# TLS
# --------------------------------------------------------------
# Add the kube-vip VIP (and optionally a DNS name) as Subject
# Alternative Names on the API server certificate. Without this,
# kubectl and kubelets will reject the VIP endpoint with a TLS
# error after kube-vip is deployed.
#   Ref: https://docs.k3s.io/datastore/cluster-loadbalancer
tls-san:
  - "{{ k3s_vip_address }}"

# --------------------------------------------------------------
# Kubeconfig
# --------------------------------------------------------------
write-kubeconfig-mode: "0644"

# --------------------------------------------------------------
# Kubelet resource reservations
# --------------------------------------------------------------
# Small mixed-role nodes need headroom for OS and control-plane
# daemons so workload spikes do not starve kubelet or system services.
{%- set system_reserved = [] %}
{%- if k3s_system_reserved_cpu is defined %}
{%- set _ = system_reserved.append('cpu=' ~ k3s_system_reserved_cpu) %}
{%- endif %}
{%- if k3s_system_reserved_memory is defined %}
{%- set _ = system_reserved.append('memory=' ~ k3s_system_reserved_memory) %}
{%- endif %}
{%- if k3s_system_reserved_ephemeral is defined %}
{%- set _ = system_reserved.append('ephemeral-storage=' ~ k3s_system_reserved_ephemeral) %}
{%- endif %}
{%- set kube_reserved = [] %}
{%- if k3s_kube_reserved_cpu is defined %}
{%- set _ = kube_reserved.append('cpu=' ~ k3s_kube_reserved_cpu) %}
{%- endif %}
{%- if k3s_kube_reserved_memory is defined %}
{%- set _ = kube_reserved.append('memory=' ~ k3s_kube_reserved_memory) %}
{%- endif %}
{%- set kubelet_args = [] %}
{%- if system_reserved | length > 0 %}
{%- set _ = kubelet_args.append('system-reserved=' ~ (system_reserved | join(','))) %}
{%- endif %}
{%- if kube_reserved | length > 0 %}
{%- set _ = kubelet_args.append('kube-reserved=' ~ (kube_reserved | join(','))) %}
{%- endif %}
{%- if k3s_eviction_hard_memory is defined %}
{%- set _ = kubelet_args.append('eviction-hard=memory.available<' ~ k3s_eviction_hard_memory) %}
{%- endif %}
{% if kubelet_args | length > 0 %}

kubelet-arg:
{% for kubelet_arg in kubelet_args %}
  - "{{ kubelet_arg }}"
{% endfor %}
{% endif %}

# --------------------------------------------------------------
# Networking (defaults — listed explicitly for documentation)
# --------------------------------------------------------------
# Flannel VXLAN is the default CNI backend. Listing it here
# makes the choice visible and auditable.
#   Ref: https://docs.k3s.io/networking/basic-network-options
flannel-backend: "vxlan"

# Default CIDRs. Ensure these don't collide with your LAN.
#   Ref: https://docs.k3s.io/networking/basic-network-options
cluster-cidr: "10.42.0.0/16"
service-cidr: "10.43.0.0/16"

# --------------------------------------------------------------
# etcd snapshots
# --------------------------------------------------------------
# Scheduled snapshots are enabled by default (every 12h, 5
# retained). We increase frequency and retention, and push
# snapshots to an S3-compatible backend (Garage) so they
# survive total cluster loss.
#   Ref: https://docs.k3s.io/cli/etcd-snapshot
etcd-snapshot-schedule-cron: "{{ etcd_snapshot_schedule_cron }}"
etcd-snapshot-retention: "{{ etcd_snapshot_retention }}"

# TODO: configure etcd s3 and backend

# --------------------------------------------------------------
# Node configuration
# --------------------------------------------------------------
# Unique node name. Prevents issues when Terraform reprovisions
# VMs that reuse the same hostname.
#   Ref: https://docs.k3s.io/installation/requirements
node-name: "{{ inventory_hostname }}"
{% set node_labels = k3s_node_labels | default([]) %}
{% if node_labels | length > 0 %}

# K3s node labels are registration-time settings. Changing them
# later may require manual relabeling or node rejoin.
node-label:
{% for label in node_labels %}
  - "{{ label }}"
{% endfor %}
{% endif %}
